<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>C.M.D. - Explore</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/CM_Events.css">
</head>
<body>
<%- include('../partials/mod-topbar') %>
<%- include('../partials/admin-topbar') %>
    <nav class="navbar">
        <a href="/" class="brand"><span class="brand-light">C.M.</span><span class="brand-accent">D.</span></a>
        <div class="nav-links">
            <a href="/events">Explore</a>
            <a href="/posts/create">Create</a>
            <a href="/users/profile">Profile</a>
            <a href="/about">About Us</a>
        </div>
        <div class="nav-right">
            <% if (currentUser) { %>
                <span><%= currentUsername %></span>
                <form action="/logout" method="POST" style="display:inline">
                    <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);text-decoration:none;background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
                </form>
            <% } else { %>
                <a href="/login" style="color:hsl(20,90%,55%);text-decoration:none;">Sign In</a>
            <% } %>
        </div>
    </nav>

    <% if (dateRangeError) { %>
    <div class="flash error" style="max-width:1200px;margin:16px auto 0;"><%= dateRangeError %></div>
    <% } %>

    <form class="search-bar" id="searchForm" action="/events" method="GET">
        <input type="text" name="q" id="search-input" value="<%= q %>" placeholder="🔍  Search activities, events, or people..." />
        <div id="hiddenFilterInputs"></div>
        <button class="btn-create" type="submit">Search</button>
    </form>

    <div class="filters-section">
        <button class="btn-filters" onclick="toggleFilterPanel()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="4" y1="6" x2="20" y2="6"></line>
                <line x1="4" y1="12" x2="20" y2="12"></line>
                <line x1="4" y1="18" x2="20" y2="18"></line>
                <circle cx="8" cy="6" r="2" fill="currentColor"></circle>
                <circle cx="16" cy="12" r="2" fill="currentColor"></circle>
                <circle cx="12" cy="18" r="2" fill="currentColor"></circle>
            </svg>
            Filters
            <span class="filter-count" id="filterCount" style="display:none;">0</span>
        </button>
        <button class="btn-clear-filters" id="clearFiltersBtn" onclick="clearAllFilters()" style="display:none;">Clear All</button>
    </div>

    <div class="filter-panel" id="filterPanel" style="display: none;">
        <div class="filter-panel-header">
            <h3>Filters</h3>
            <button class="btn-close" onclick="toggleFilterPanel()">✕</button>
        </div>
        <div class="filter-panel-content">
            <div class="filter-group">
                <label class="filter-label">Categories</label>
                <div class="filter-pills" id="categoryFilters">
                    <% categories.forEach(function(cat) { %>
                        <button type="button" class="filter-pill" data-cat="<%= cat.name %>"><%= cat.name %></button>
                    <% }); %>
                </div>
            </div>
            <div class="filter-group">
                <label class="filter-label">Date Range</label>
                <div id="customDateRange">
                    <input type="date" id="filterDateFrom" />
                    <span style="color:#888;font-size:0.85rem;flex-shrink:0;">to</span>
                    <input type="date" id="filterDateTo" />
                </div>
            </div>
            <div class="filter-group filter-group--disabled">
                <label class="filter-label">
                    Distance
                    <span class="filter-tag-coming-soon">Coming soon</span>
                </label>
                <div class="filter-distance">
                    <select disabled>
                        <option>Within 5 miles</option>
                        <option>Within 10 miles</option>
                        <option>Within 25 miles</option>
                        <option>Within 50 miles</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="filter-panel-footer">
            <button class="btn-apply-filters" onclick="applyFilters()">Apply Filters</button>
        </div>
    </div>

    <div class="filter-overlay" id="filterOverlay" onclick="toggleFilterPanel()"></div>

    <script>
        window.INIT_CATEGORIES = <%- JSON.stringify(selectedCategories) %>;
        window.INIT_DATE_FROM  = '<%- dateFrom %>';
        window.INIT_DATE_TO    = '<%- dateTo %>';
    </script>

    <div class="main-content">
        <div class="cards-panel">
            <div class="cards-grid">

                <% var colors = ['#2e3a4e','#3b4a2e','#3b2e4a','#2e4a3b','#4a3b2e','#4a2e3b']; %>
                <% posts.forEach(function(post, i) { %>
                <%
                                    var rsvpCount = rsvpCounts[post.id] || 0;
                  var rsvpLabel = post.maxAttendees ? (rsvpCount + '/' + post.maxAttendees) : (rsvpCount + ' going');
                  var postColor = colors[i % colors.length];
                  var postTags = Array.isArray(post.category) ? post.category : [];
                  var postDesc = post.description ? post.description.substring(0, 100) : '';
                  var postDate = post.date ? new Date(post.date).toDateString() : 'Date TBD';
                                    var isInterested = interestedPostIds && interestedPostIds.includes(post.id);
                %>
                <div class="card"
                     data-post-id="<%= post.id %>"
                     data-post-title="<%= post.title.replace(/"/g, '&quot;') %>"
                     data-post-desc="<%= postDesc.replace(/"/g, '&quot;') %>"
                     data-post-date="<%= postDate %>"
                     data-post-going="<%= rsvpCount %>"
                     data-post-max="<%= post.maxAttendees || '' %>"
                     data-post-color="<%= postColor %>"
                     data-post-tags="<%= JSON.stringify(postTags) %>"
                     data-post-image="<%= post.imageUrl || '' %>"
                     onclick="window.location.href='/posts/<%= post.id %>'" style="cursor:pointer;">
                    <% if (post.imageUrl) { %>
                        <div class="card-img" style="background-color:<%= postColor %>;">
                            <img src="<%= post.imageUrl %>" alt="" style="width:100%;height:100%;object-fit:cover;">
                        </div>
                    <% } else { %>
                        <div class="card-img" style="background-color:<%= postColor %>;"><div class="img-placeholder"></div></div>
                    <% } %>
                    <div class="card-tags">
                        <div class="tags-left">
                            <% postTags.forEach(function(cat) { %>
                                <span class="tag"><%= cat %></span>
                            <% }); %>
                        </div>
                        <div class="card-tags-right">
                            <span class="rsvp-count"><%= rsvpLabel %></span>
                            <button class="star-btn <%= isInterested ? 'interested' : '' %>" onclick="event.stopPropagation(); toggleStar(this)" aria-label="Mark as interested">
                                <svg class="star-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                </svg>
                                <span class="interested-label">Interested</span>
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="card-title"><%= post.title %></div>
                        <div class="card-desc"><%= post.description ? post.description.substring(0, 100) + (post.description.length > 100 ? '...' : '') : '' %></div>
                    </div>
                    <div class="card-footer">
                        <span><% if (post.date) { %>📅 <%= new Date(post.date).toDateString() %><% } else { %>📅 Date TBD<% } %></span>
                        <% if (post.location) { %><span class="card-location">📍 <%= post.location %></span><% } %>
                        <% if (post.author) { %><span>👤 <%= post.author.name %></span><% } %>
                    </div>
                </div>
                <% }); %>

                <% if (posts.length === 0) { %>
                <div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:#666;">
                    <div style="font-size:3rem;margin-bottom:16px;">📭</div>
                    <h3 style="margin-bottom:8px;">No posts found</h3>
                    <p>Try changing your search or filter, or <a href="/posts/create" style="color:hsl(20,90%,55%);">create a post</a>.</p>
                </div>
                <% } %>

            </div>
        </div>

        <div class="map-panel">
            <svg width="100%" height="100%" viewBox="0 0 800 900" preserveAspectRatio="none"></svg>
            <div class="map-label">Map View</div>
        </div>
    </div>

    <footer>
        <div class="container">
            <span class="logo">C.M.D.</span>
            <p>Connect. Meet. Discover. © 2026</p>
        </div>
    </footer>

    <script src="/js/CM_Events.js"></script>
</body>
</html>
