<% if (currentRole === 'admin') { %>
<style>
  .admin-topbar-bar {
    background: hsl(215, 20%, 30%);
    color: #fff;
    padding: 0.5rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.875rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .admin-topbar-bar a { text-decoration: none; }
  .admin-topbar-label {
    color: #fff;
    font-weight: 500;
  }
  .admin-topbar-label:hover { text-decoration: underline; }
  .admin-topbar-badge {
    font-weight: 500;
    color: white;
    padding: 0.375rem 1rem;
    border-radius: 24px;
    background: rgba(229, 115, 77, 0.15);
    border: 1px solid hsl(20, 90%, 55%);
    font-size: 0.75rem;
  }
  .admin-topbar-badge:hover { background: rgba(229, 115, 77, 0.3); color: white; }
</style>
<div class="admin-topbar-bar">
  <a href="/admin/users" class="admin-topbar-label">System Administrator Dashboard</a>
  <a href="/admin/users" class="admin-topbar-badge">System Administrator</a>
</div>
<% } %>
