<% if (userWarnings && userWarnings.length > 0) { %>
<style>
  .warning-indicator { position: relative; display: inline-block; vertical-align: middle; margin-left: 0.5rem; }
  .warning-dot { display: inline-block; width: 12px; height: 12px; background: #e87000; border-radius: 50%; cursor: pointer; animation: warnpulse 1.5s infinite; vertical-align: middle; }
  @keyframes warnpulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
  .warning-popup { position: absolute; top: 1.8rem; right: 0; background: #fff; border: 1px solid #e87000; border-radius: 8px; padding: 1rem; min-width: 280px; max-width: 360px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); z-index: 9999; }
  .warning-popup h4 { margin: 0 0 0.5rem; color: #e87000; font-size: 0.95rem; }
  .warning-item { border-bottom: 1px solid #f0f0f0; padding: 0.5rem 0; font-size: 0.85rem; color: #333; }
  .warning-item:last-of-type { border-bottom: none; }
  .warning-item small { color: #888; display: block; margin-top: 0.2rem; }
  .warning-dismiss-btn { margin-top: 0.75rem; background: #e87000; color: #fff; border: none; border-radius: 5px; padding: 0.35rem 0.8rem; font-size: 0.8rem; cursor: pointer; width: 100%; }
  .warning-dismiss-btn:hover { background: #c56000; }
</style>
<div class="warning-indicator" id="warningIndicator">
  <span class="warning-dot" id="warningDot" title="You have a moderator warning"></span>
  <div class="warning-popup" id="warningPopup" style="display:none;">
    <h4>&#9888; Moderator Warning</h4>
    <% userWarnings.forEach(function(w) { %>
      <div class="warning-item">
        <p style="margin:0"><%= w.message %></p>
        <small><%= new Date(w.createdAt).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %></small>
      </div>
    <% }); %>
    <form action="/users/warnings/dismiss" method="POST">
      <button type="submit" class="warning-dismiss-btn">Dismiss</button>
    </form>
  </div>
</div>
<script>
  (function() {
    var dot = document.getElementById('warningDot');
    var popup = document.getElementById('warningPopup');
    dot.addEventListener('click', function(e) {
      e.stopPropagation();
      popup.style.display = popup.style.display === 'none' ? 'block' : 'none';
    });
    document.addEventListener('click', function() {
      popup.style.display = 'none';
    });
  })();
</script>
<% } %>
