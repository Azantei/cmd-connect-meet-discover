<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>C.M.D. - Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/CM_Profile.css">
</head>
<body>

    <nav class="navbar">
        <a href="/" class="brand"><span class="brand-light">C.M.</span><span class="brand-accent">D.</span></a>
        <div class="nav-links">
            <a href="/events">Explore</a>
            <a href="/posts/create">Create</a>
            <a href="/users/profile">Profile</a>
            <a href="/about">About Us</a>
        </div>
        <div class="nav-right">
            <% if (currentUser) { %>
                <span><%= currentUsername %></span>
                <form action="/logout" method="POST" style="display:inline">
                    <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);text-decoration:none;background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
                </form>
            <% } else { %>
                <a href="/login" style="color:hsl(20,90%,55%);text-decoration:none;">Sign In</a>
            <% } %>
        </div>
    </nav>

    <%
      const nameParts = (profileUser.name || '').split(' ').filter(Boolean);
      const initials = nameParts.slice(0,2).map(p => p[0].toUpperCase()).join('') || '?';
    %>

    <div class="profile-header">
        <div class="profile-left">
            <% if (profileUser.profilePic) { %>
                <img src="<%= profileUser.profilePic %>" class="avatar" style="object-fit:cover;" alt="Profile picture">
            <% } else { %>
                <div class="avatar"><%= initials %></div>
            <% } %>
            <div class="profile-info">
                <div class="profile-name-row">
                    <span class="profile-name"><%= profileUser.name %></span>
                </div>
                <div class="profile-handle"><%= profileUser.location || 'C.M.D. Community' %></div>
                <div class="profile-stats">
                    <div><span class="stat-num"><%= posts.length %></span><span class="stat-label">Posts</span></div>
                    <div><span class="stat-num"><%= upcomingRsvps.length + pastEvents.length %></span><span class="stat-label">Events</span></div>
                </div>
            </div>
        </div>
        <a href="/users/settings" class="btn-edit">Edit Profile</a>
    </div>

    <div class="tabs">
        <button class="tab active" onclick="setTab(this, 'my-posts')">My Posts</button>
        <button class="tab" onclick="setTab(this, 'upcoming')">My RSVPs</button>
        <button class="tab" onclick="setTab(this, 'interested')">Interested</button>
        <button class="tab" onclick="setTab(this, 'previous')">Previous Events</button>
        <button class="tab" onclick="setTab(this, 'drafts')">Drafts</button>
    </div>

    <div class="main-layout">
        <div class="sidebar">
            <div class="sidebar-section-title">INTERESTS</div>
            <div class="interests-box">
                <% (profileUser.interests || []).forEach(function(interest) { %>
                    <span class="interest-tag"><%= interest %></span>
                <% }); %>
                <% if (!profileUser.interests || profileUser.interests.length === 0) { %>
                    <span style="color:#888;font-size:0.85rem;">No interests set yet.</span>
                <% } %>
            </div>
        </div>

        <div class="posts-area">
            <div class="toolbar">
                <div class="dropdown-wrap">
                    <button class="toolbar-btn" onclick="toggleSort()">↕ Sort: <span id="sortLabel">Newest</span> ▾</button>
                    <div class="dropdown" id="sortDropdown">
                        <div class="dropdown-item active-item" onclick="setSort(this, 'Newest')">Newest</div>
                        <div class="dropdown-item" onclick="setSort(this, 'Oldest')">Oldest</div>
                        <div class="dropdown-item" onclick="setSort(this, 'Most Popular')">Most Popular</div>
                        <div class="dropdown-item" onclick="setSort(this, 'Upcoming')">Upcoming</div>
                    </div>
                </div>
                <button class="toolbar-btn" id="filterBtn" onclick="toggleFilter()">⚙ Filter by Interests <span id="filterCount"></span> ▾</button>
                <button class="clear-btn" id="clearBtn" onclick="clearFilters()" style="display:none;">✕ Clear</button>
            </div>

            <div class="filter-panel" id="filterPanel" style="display:none;">
                <div class="filter-title">FILTER BY INTERESTS</div>
                <div class="filter-pills">
                    <% (profileUser.interests || []).forEach(function(interest) { %>
                        <button class="fpill" onclick="toggleCatFilter(this)" data-cat="<%= interest %>"><%= interest %></button>
                    <% }); %>
                </div>
            </div>

            <div class="scrollable-content">
                <div class="cards-grid" id="cardsGrid"></div>
                <div class="no-results" id="noResults" style="display:none;">No posts match the selected filters.</div>
            </div>
        </div>
    </div>

    <footer>
        <div class="container">
            <span class="logo">C.M.D.</span>
            <p>Connect. Meet. Discover. &copy; 2026</p>
        </div>
    </footer>

    <script src="/js/CM_Profile.js"></script>
    <script>
      // Seed JS data arrays with real server data then re-render
      var _rsvpCounts = <%- JSON.stringify(rsvpCounts) %>;
      MY_POSTS = <%- JSON.stringify(posts.map(function(p) {
        return {
          title: p.title || '',
          desc:  p.description || '',
          date:  p.date ? new Date(p.date).toDateString() : 'Date TBD',
          going: rsvpCounts[p.id] || 0,
          maxAttendees: null,
          color: '#2e3a4e',
          tags:  Array.isArray(p.category) ? p.category : [],
          status: 'Published',
          id: p.id,
          imageUrl: p.imageUrl || null
        };
      })) %>;
      UPCOMING_EVENTS = <%- JSON.stringify(upcomingRsvps.map(function(r) {
        var p = r.Post || {};
        return {
          title: p.title || '',
          desc:  p.description || '',
          date:  p.date ? new Date(p.date).toDateString() : 'Date TBD',
          going: rsvpCounts[p.id] || 0,
          maxAttendees: p.maxAttendees || null,
          color: '#3b4a2e',
          tags:  Array.isArray(p.category) ? p.category : [],
          rsvp:  'Going',
          id:    p.id,
          imageUrl: p.imageUrl || null
        };
      })) %>;
      PREVIOUS_EVENTS = <%- JSON.stringify(pastEvents.map(function(p) {
        return {
          title: p.title || '',
          desc:  p.description || '',
          date:  p.date ? new Date(p.date).toDateString() : 'Date TBD',
          going: rsvpCounts[p.id] || 0,
          maxAttendees: p.maxAttendees || null,
          color: '#2e3a4e',
          tags:  Array.isArray(p.category) ? p.category : [],
          type:  'attended',
          id:    p.id,
          imageUrl: p.imageUrl || null
        };
      })) %>;
      INTERESTED_EVENTS = JSON.parse(localStorage.getItem('cmd_interested_events') || '[]');
      DRAFTS = <%- JSON.stringify(drafts.map(function(p) {
        return {
          title: p.title || '',
          desc:  p.description || '',
          date:  'Draft',
          going: 0,
          color: '#3b3b3b',
          tags:  Array.isArray(p.category) ? p.category : [],
          status: 'Draft',
          id: p.id,
          imageUrl: p.imageUrl || null
        };
      })) %>;
      renderCards();
    </script>
</body>
</html>
