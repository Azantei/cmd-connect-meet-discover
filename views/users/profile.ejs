<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>C.M.D. - Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/CM_Profile.css">
</head>
<body>

    <nav class="navbar">
        <a href="/" class="brand"><span class="brand-light">C.M.</span><span class="brand-accent">D.</span></a>
        <div class="nav-links">
            <a href="/events">Explore</a>
            <a href="/posts/create">Create</a>
            <a href="/users/profile">Profile</a>
            <a href="/about">About Us</a>
        </div>
        <div class="nav-right">
            <% if (currentUser) { %>
                <span><%= currentUsername %></span>
                <form action="/logout" method="POST" style="display:inline">
                    <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
                </form>
            <% } else { %>
                <a href="/login" style="color:hsl(20,90%,55%);text-decoration:none;">Sign In</a>
            <% } %>
        </div>
    </nav>

    <% if (success && success.length) { %><div class="flash success"><%= success %></div><% } %>
    <% if (error && error.length) { %><div class="flash error"><%= error %></div><% } %>

    <div class="profile-header">
        <div class="profile-left">
            <% if (profileUser.profilePic) { %>
                <img src="<%= profileUser.profilePic %>" alt="Profile picture"
                     class="avatar" style="object-fit:cover;">
            <% } else { %>
                <div class="avatar"><%= profileUser.name ? profileUser.name.charAt(0).toUpperCase() : '?' %></div>
            <% } %>
            <div class="profile-info">
                <div class="profile-name-row">
                    <span class="profile-name"><%= profileUser.name %></span>
                </div>
                <% if (profileUser.location) { %>
                    <div class="profile-handle"><%= profileUser.location %></div>
                <% } %>
                <div class="profile-stats">
                    <div><span class="stat-num"><%= posts.length %></span><span class="stat-label">Posts</span></div>
                    <div><span class="stat-num"><%= rsvps.length %></span><span class="stat-label">RSVPs</span></div>
                </div>
            </div>
        </div>
        <a href="/users/settings" class="btn-edit">Edit Profile</a>
    </div>

    <div class="main-layout">
        <div class="sidebar">
            <% if (profileUser.interests && profileUser.interests.length) { %>
                <div class="sidebar-section-title">INTERESTS</div>
                <div class="interests-box">
                    <% profileUser.interests.forEach(interest => { %>
                        <span class="interest-tag"><%= interest %></span>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <div class="posts-area">
            <h2>My Posts</h2>
            <% if (posts.length === 0) { %>
                <p>No posts yet. <a href="/posts/new">Create one!</a></p>
            <% } else { %>
                <div class="cards-grid">
                    <% posts.forEach(post => { %>
                        <div class="post-card">
                            <h3><a href="/posts/<%= post.id %>"><%= post.title %></a></h3>
                            <% if (post.category) { %><span class="tag"><%= post.category %></span><% } %>
                            <% if (post.description) { %>
                                <p><%= post.description.substring(0, 120) %><%= post.description.length > 120 ? '...' : '' %></p>
                            <% } %>
                            <small><%= new Date(post.createdAt).toLocaleDateString() %></small>
                        </div>
                    <% }) %>
                </div>
            <% } %>

            <% if (rsvps.length > 0) { %>
                <h2>RSVPs</h2>
                <div class="cards-grid">
                    <% rsvps.forEach(rsvp => { %>
                        <% if (rsvp.Post) { %>
                            <div class="post-card">
                                <h3><a href="/posts/<%= rsvp.Post.id %>"><%= rsvp.Post.title %></a></h3>
                                <% if (rsvp.Post.category) { %><span class="tag"><%= rsvp.Post.category %></span><% } %>
                            </div>
                        <% } %>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </div>

    <footer>
        <div class="container">
            <span class="logo">C.M.D.</span>
            <p>Connect. Meet. Discover. &copy; 2026</p>
        </div>
    </footer>

    <script src="/js/CM_Profile.js"></script>
</body>
</html>
