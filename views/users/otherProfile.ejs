<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>C.M.D. - User Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/CM_OtherUserProfile.css">
</head>
<body>

    <nav class="navbar">
        <a href="/" class="brand"><span class="brand-light">C.M.</span><span class="brand-accent">D.</span></a>
        <div class="nav-links">
            <a href="/events">Explore</a>
            <a href="/posts/create">Create</a>
            <a href="/users/profile">Profile</a>
            <a href="/about">About Us</a>
        </div>
        <div class="nav-right">
            <% if (currentUser) { %>
                <span><%= currentUsername %></span>
                <form action="/logout" method="POST" style="display:inline">
                    <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);text-decoration:none;background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
                </form>
            <% } else { %>
                <a href="/login" style="color:hsl(20,90%,55%);text-decoration:none;">Sign In</a>
            <% } %>
        </div>
    </nav>

    <div class="profile-header">
        <div class="profile-left">
            <div class="avatar">?</div>
            <div class="profile-info">
                <div class="profile-name">Other User's Name</div>
                <div class="profile-meta">
                    <span class="meta-link">@username</span>
                    <span class="meta-link">Location</span>
                </div>
                <div class="profile-stats">
                    <div><span class="stat-num">16</span><span class="stat-label">Posts</span></div>
                    <div><span class="stat-num">78</span><span class="stat-label">RSVPs</span></div>
                </div>
            </div>
        </div>
        <button class="btn-report" id="reportBtn" onclick="openReportModal()">Report User</button>
    </div>

    <div class="main-layout">
        <div class="sidebar">
            <div class="sidebar-section-title">ABOUT</div>
            <div class="placeholder-lines">Example Bio</div>
            <hr class="sidebar-divider">
            <div class="sidebar-section-title">INTERESTS</div>
            <div class="interests-box">
                <span class="interest-tag">Music</span>
                <span class="interest-tag">Sports</span>
                <span class="interest-tag">Tech</span>
            </div>
        </div>

        <div class="posts-area">
            <div class="section-header">
                <h2 class="section-title">Previously Attended Events</h2>
                <p class="section-subtitle">Only visible if privacy settings allow</p>
            </div>

            <div class="toolbar">
                <div class="dropdown-wrap">
                    <button class="toolbar-btn" onclick="toggleSort()">↕ Sort: <span id="sortLabel">Newest</span> ▾</button>
                    <div class="dropdown" id="sortDropdown">
                        <div class="dropdown-item active-item" onclick="setSort(this, 'Newest')">Newest</div>
                        <div class="dropdown-item" onclick="setSort(this, 'Oldest')">Oldest</div>
                        <div class="dropdown-item" onclick="setSort(this, 'Most Popular')">Most Popular</div>
                    </div>
                </div>
                <button class="toolbar-btn" id="filterBtn" onclick="toggleFilter()">⚙ Filter by Interests <span id="filterCount"></span> ▾</button>
                <button class="clear-btn" id="clearBtn" onclick="clearFilters()" style="display:none;">✕ Clear</button>
            </div>

            <div class="filter-panel" id="filterPanel" style="display:none;">
                <div class="filter-title">FILTER BY INTERESTS</div>
                <div class="filter-pills">
                    <button class="fpill" onclick="toggleCatFilter(this)" data-cat="Outdoors">Outdoors</button>
                    <button class="fpill" onclick="toggleCatFilter(this)" data-cat="Music">Music</button>
                    <button class="fpill" onclick="toggleCatFilter(this)" data-cat="Sports">Sports</button>
                    <button class="fpill" onclick="toggleCatFilter(this)" data-cat="Food">Food</button>
                    <button class="fpill" onclick="toggleCatFilter(this)" data-cat="Arts">Arts</button>
                    <button class="fpill" onclick="toggleCatFilter(this)" data-cat="Tech">Tech</button>
                    <button class="fpill" onclick="toggleCatFilter(this)" data-cat="Fitness">Fitness</button>
                    <button class="fpill" onclick="toggleCatFilter(this)" data-cat="Games">Games</button>
                </div>
            </div>

            <div class="scrollable-content">
                <div class="cards-grid" id="cardsGrid"></div>
                <div class="no-results" id="noResults" style="display:none;">This user's previously attended events are not public.</div>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="reportModal" style="display:none;">
        <div class="modal">
            <div class="modal-title">Report this user?</div>
            <div class="modal-desc">Please select a reason for reporting this user. Our team will review the report.</div>
            <div class="modal-reasons">
                <label><input type="radio" name="reason"> Spam or misleading content</label>
                <label><input type="radio" name="reason"> Harassment or bullying</label>
                <label><input type="radio" name="reason"> Inappropriate content</label>
                <label><input type="radio" name="reason"> Other</label>
            </div>
            <div class="modal-comment-section">
                <label for="reportComment" class="comment-label">Additional Comments (optional)</label>
                <textarea id="reportComment" class="report-textarea" rows="3" placeholder="Provide any additional details that might help our moderation team..."></textarea>
            </div>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeReportModal()">Cancel</button>
                <button class="btn-submit" onclick="submitReport()">Submit Report</button>
            </div>
        </div>
    </div>

    <footer>
        <div class="container">
            <span class="logo">C.M.D.</span>
            <p>Connect. Meet. Discover. © 2026</p>
        </div>
    </footer>

    <script src="/js/CM_OtherUserProfile.js"></script>
</body>
</html>
