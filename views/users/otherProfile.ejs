<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>C.M.D. - <%= profileUser.name %>'s Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/CM_OtherUserProfile.css">
</head>
<body>
<%- include('../partials/mod-topbar') %>
<%- include('../partials/admin-topbar') %>
    <nav class="navbar">
        <a href="/" class="brand"><span class="brand-light">C.M.</span><span class="brand-accent">D.</span></a>
        <div class="nav-links">
            <a href="/events">Explore</a>
            <a href="/posts/create">Create</a>
            <a href="/users/profile">Profile</a>
            <a href="/about">About Us</a>
        </div>
        <div class="nav-right">
            <% if (currentUser) { %>
                <span><%= currentUsername %></span>
                <form action="/logout" method="POST" style="display:inline">
                    <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
                </form>
            <% } else { %>
                <a href="/login" style="color:hsl(20,90%,55%);text-decoration:none;">Sign In</a>
            <% } %>
        </div>
    </nav>

    <% if (success && success.length) { %><div class="flash success"><%= success %></div><% } %>
    <% if (error && error.length) { %><div class="flash error"><%= error %></div><% } %>

    <div class="profile-header">
        <div class="profile-left">
            <% if (profileUser.profilePic) { %>
                <img src="<%= profileUser.profilePic %>" alt="Profile picture"
                     class="avatar" style="object-fit:cover;">
            <% } else { %>
                <div class="avatar"><%= profileUser.name ? profileUser.name.charAt(0).toUpperCase() : '?' %></div>
            <% } %>
            <div class="profile-info">
                <div class="profile-name"><%= profileUser.name %></div>
                <% if (profileUser.location && profileUser.showLocation !== false) { %>
                    <div class="profile-meta">
                        <span class="meta-link"><%= profileUser.location %></span>
                    </div>
                <% } %>
                <div class="profile-stats">
                    <div><span class="stat-num"><%= posts.length %></span><span class="stat-label">Posts</span></div>
                </div>
            </div>
        </div>
        <% if (currentUser && currentUser !== profileUser.id) { %>
            <button class="btn-report" id="reportBtn" onclick="document.getElementById('reportModal').style.display='flex'">Report User</button>
        <% } %>
    </div>

    <div class="main-layout">
        <div class="sidebar">
            <% if (profileUser.interests && profileUser.interests.length && profileUser.showInterests !== false) { %>
                <div class="sidebar-section-title">INTERESTS</div>
                <div class="interests-box">
                    <% profileUser.interests.forEach(interest => { %>
                        <span class="interest-tag"><%= interest %></span>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <div class="posts-area">
            <div class="section-header">
                <div class="section-title"><%= profileUser.name %>'s Posts</div>
                <div class="section-subtitle"><%= posts.length %> post<%= posts.length !== 1 ? 's' : '' %></div>
            </div>
            <div class="toolbar">
                <div class="dropdown-wrap">
                    <button class="toolbar-btn" onclick="toggleSort()">Sort: <span id="sortLabel">Newest</span> ▾</button>
                    <div class="dropdown" id="sortDropdown">
                        <div class="dropdown-item active-item" onclick="setSort(this,'Newest')">Newest</div>
                        <div class="dropdown-item" onclick="setSort(this,'Oldest')">Oldest</div>
                    </div>
                </div>
                <button class="toolbar-btn" id="filterBtn" onclick="toggleFilter()">Filter <span id="filterCount"></span> ▾</button>
                <button class="clear-btn" id="clearBtn" style="display:none" onclick="clearFilters()">Clear Filters</button>
            </div>
            <div class="filter-panel" id="filterPanel" style="display:none;">
                <div class="filter-title">CATEGORIES</div>
                <div class="filter-pills">
                    <% categories.forEach(function(cat) { %>
                        <span class="fpill" data-cat="<%= cat.name %>" onclick="toggleCatFilter(this)"><%= cat.name %></span>
                    <% }); %>
                </div>
            </div>
            <div class="scrollable-content">
                <div class="cards-grid" id="cardsGrid"></div>
                <div class="no-results" id="noResults" style="display:none;">No posts found.</div>
            </div>
        </div>
    </div>

    <% if (currentUser && currentUser !== profileUser.id) { %>
    <div class="modal-overlay" id="reportModal" style="display:none;">
        <div class="modal">
            <div class="modal-title">Report this user?</div>
            <div class="modal-desc">Please describe why you are reporting this user.</div>
            <form action="/users/<%= profileUser.id %>/report" method="POST">
                <div class="modal-comment-section">
                    <label for="reportReason" class="comment-label">Reason <span style="color:red">*</span></label>
                    <textarea id="reportReason" name="reason" class="report-textarea" rows="3"
                        placeholder="Describe the issue..." required></textarea>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-cancel" onclick="document.getElementById('reportModal').style.display='none'">Cancel</button>
                    <button type="submit" class="btn-submit">Submit Report</button>
                </div>
            </form>
        </div>
    </div>
    <% } %>

    <footer>
        <div class="container">
            <span class="logo">C.M.D.</span>
            <p>Connect. Meet. Discover. &copy; 2026</p>
        </div>
    </footer>

    <% if (reportSuccess && reportSuccess.length) { %>
    <div class="modal-overlay" id="reportSuccessModal" style="display:flex;">
        <div class="modal">
            <div class="modal-title">Report Submitted</div>
            <div class="modal-desc"><%= reportSuccess %></div>
            <div class="modal-actions" style="justify-content:center;">
                <button type="button" class="btn-submit" onclick="document.getElementById('reportSuccessModal').style.display='none'">OK</button>
            </div>
        </div>
    </div>
    <% } %>

    <script src="/js/CM_OtherUserProfile.js"></script>
    <script>
            PROFILE_POSTS = <%- JSON.stringify(profilePostsCards) %>;
      renderCards();
    </script>
    <% if (attendedEvents && attendedEvents.length > 0) { %>
    <div class="main-layout" style="margin-top:0;">
        <div class="sidebar"></div>
        <div class="posts-area">
            <div class="section-header">
                <div class="section-title">Previously Attended Events</div>
                <div class="section-subtitle"><%= attendedEvents.length %> event<%= attendedEvents.length !== 1 ? 's' : '' %></div>
            </div>
            <div class="scrollable-content">
                <div class="cards-grid">
                    <% attendedEvents.forEach(function(p, i) { %>
                        <a href="/posts/<%= p.id %>" style="text-decoration:none;color:inherit;display:block;">
                            <div class="card">
                                <% if (p.imageUrl) { %>
                                    <div class="card-img" style="background-color:<%= ['#2e3a4e','#3b4a2e','#3b2e4a','#4a3b2e','#2e4a3b'][i % 5] %>"><img src="<%= p.imageUrl %>" alt="" style="width:100%;height:100%;object-fit:cover;display:block;"></div>
                                <% } else { %>
                                    <div class="card-img" style="background-color:<%= ['#2e3a4e','#3b4a2e','#3b2e4a','#4a3b2e','#2e4a3b'][i % 5] %>"><div class="card-img-icon"></div></div>
                                <% } %>
                                <div class="card-tags">
                                    <% (Array.isArray(p.category) ? p.category : []).forEach(function(t) { %><span class="card-tag"><%= t %></span><% }) %>
                                    <span class="status-badge" style="background-color:#2e7d32;">✓ Attended</span>
                                </div>
                                <div class="card-body">
                                    <div class="card-title"><%= p.title %></div>
                                    <div class="card-desc"><%= p.description || '' %></div>
                                </div>
                                <div class="card-footer">
                                    <span>📅 <%= p.date ? new Date(p.date).toDateString() : 'Date TBD' %></span>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
    <% } %>
</body>
</html>
