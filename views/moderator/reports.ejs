<%- include('../partials/header', { pageCSS: 'moderator' }) %>
<main>
  <h1>Report Detail</h1>
  <div>
    <p><strong>Target:</strong> <%= report.title %></p>
    <p><strong>Reported by:</strong> <%= report.reporter %></p>
    <p><strong>Reason:</strong> <%= report.reason %></p>
    <form action="/moderator/reports/<%= report.id %>/warn" method="POST" style="display:inline">
      <textarea name="notes" placeholder="Note (optional)"></textarea>
      <button type="submit">Warn User</button>
    </form>
    <form action="/moderator/reports/<%= report.id %>/dismiss" method="POST" style="display:inline">
      <textarea name="notes" placeholder="Note (optional)"></textarea>
      <button type="submit">Dismiss</button>
    </form>
    <form action="/moderator/reports/<%= report.id %>/escalate" method="POST" style="display:inline">
      <input type="hidden" name="escalationReason" value="Policy violation">
      <textarea name="notes" placeholder="Note (optional)"></textarea>
      <button type="submit">Escalate to Admin</button>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
