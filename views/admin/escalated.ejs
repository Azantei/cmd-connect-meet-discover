<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Escalated Reports | C.M.D.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/AD_EscalatedReports.css">
  <style>
    .admin-popup { position:fixed; top:1.5rem; left:50%; transform:translateX(-50%); padding:.75rem 1.5rem; border-radius:8px; font-size:.95rem; font-weight:600; box-shadow:0 4px 16px rgba(0,0,0,.2); z-index:10000; animation:adFadeIn .3s ease; }
    .admin-popup.success { background:#276749; color:#fff; }
    .admin-popup.error   { background:#c53030; color:#fff; }
    @keyframes adFadeIn { from{opacity:0;transform:translateX(-50%) translateY(-12px)} to{opacity:1;transform:translateX(-50%) translateY(0)} }
  </style>
</head>
<body>
  <header class="admin-topbar">
    <span>System Administrator Dashboard</span>
    <span class="admin-role">System Administrator</span>
  </header>

  <nav class="top-navbar">
    <div class="navbar-content">
      <a href="/" class="logo"><span class="logo-light">C.M.</span><span class="logo-accent">D.</span></a>
      <div class="nav-links">
        <a href="/events">Explore</a>
        <a href="/posts/create">Create</a>
        <a href="/users/profile">Profile</a>
        <a href="/about">About Us</a>
      </div>
      <div class="admin-info">Admin: <%= currentUsername %>
        <form action="/logout" method="POST" style="display:inline">
          <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
        </form>
      </div>
    </div>
  </nav>

  <aside class="left-sidebar">
    <nav class="sidebar-nav">
      <a href="/admin/users" class="nav-item"><span>Users</span></a>
      <a href="/admin/escalated" class="nav-item active"><span>Escalated</span><% if (escalatedCount > 0) { %><span class="escalated-dot"></span><% } %></a>
      <a href="/admin/analytics" class="nav-item"><span>Analytics</span></a>
      <a href="/admin/settings" class="nav-item"><span>Settings</span></a>
    </nav>
  </aside>

  <% if (success && success.length) { %><div class="admin-popup success" id="adminPopup"><%= success %></div><% } %>
  <% if (error && error.length) { %><div class="admin-popup error" id="adminPopup"><%= error %></div><% } %>
  <% if ((success && success.length) || (error && error.length)) { %>
  <script>setTimeout(function(){ var el=document.getElementById('adminPopup'); if(el) el.remove(); }, 4000);</script>
  <% } %>

  <main class="main-content">

    <section class="page-header">
      <h1>Escalated Reports</h1>
      <div class="filter-group">
        <label for="statusFilter">Status:</label>
        <select id="statusFilter" class="status-filter">
          <option value="all">All</option>
          <option value="open">Open</option>
          <option value="resolved">Resolved</option>
        </select>
      </div>
    </section>

    <section class="reports-list" id="reportsList"></section>
  </main>

  <div id="reportDetailModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2 id="modalReportTitle">Report Details</h2>
        <button class="modal-close" onclick="closeReportDetail()">&times;</button>
      </div>
      <div class="modal-body">
        <div class="detail-section">
          <h3>Report Information</h3>
          <div id="modalReportMeta" class="detail-meta"></div>
        </div>
        <div class="detail-section">
          <h3>Moderator Notes</h3>
          <div id="modalModeratorNotes" class="detail-content"></div>
        </div>
        <div class="detail-section">
          <h3>Reported Content</h3>
          <div id="modalContentPreview" class="detail-content"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button id="btnBanUser" class="modal-action-btn ban-user" onclick="handleBanUser()">Ban User</button>
        <button id="btnRemoveContent" class="modal-action-btn remove-content" onclick="handleRemoveContent()">Remove Post</button>
        <button id="btnDismissReport" class="modal-action-btn dismiss" onclick="handleDismissReport()">Dismiss Report</button>
      </div>
    </div>
  </div>

  <div id="confirmationModal" class="modal">
    <div class="modal-content modal-small">
      <div class="modal-header">
        <h2>Confirm Action</h2>
      </div>
      <div class="modal-body">
        <p id="confirmationMessage" class="confirmation-text"></p>
        <p class="warning-text">&#9888;&#65039; This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button class="modal-action-btn secondary" onclick="closeConfirmation()">Cancel</button>
        <button id="confirmActionBtn" class="modal-action-btn primary">Confirm</button>
      </div>
    </div>
  </div>

  <footer>
    <div class="container">
      <span class="logo">C.M.D.</span>
      <p>Connect. Meet. Discover. &copy; 2026</p>
    </div>
  </footer>

  <script>
    window.ADMIN_ESCALATED = <%- JSON.stringify(escalatedRows) %>;
  </script>
  <script src="/js/AD_EscalatedReports.js"></script>
</body>
</html>
