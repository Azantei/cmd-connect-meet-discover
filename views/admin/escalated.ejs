<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Escalated Reports | C.M.D.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/AD_EscalatedReports.css">
</head>
<body>
  <header class="admin-topbar">
    <span>System Administrator Dashboard</span>
    <span class="admin-role">System Administrator</span>
  </header>

  <nav class="top-navbar">
    <div class="navbar-content">
      <a href="/" class="logo"><span class="logo-light">C.M.</span><span class="logo-accent">D.</span></a>
      <div class="nav-links">
        <a href="/events">Explore</a>
        <a href="/posts/create">Create</a>
        <a href="/users/profile">Profile</a>
        <a href="/about">About Us</a>
      </div>
      <div class="admin-info">Admin: <%= currentUsername %>
        <form action="/logout" method="POST" style="display:inline">
          <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
        </form>
      </div>
    </div>
  </nav>

  <aside class="left-sidebar">
    <nav class="sidebar-nav">
      <a href="/admin/users" class="nav-item"><span>Users</span></a>
      <a href="/admin/escalated" class="nav-item active"><span>Escalated</span></a>
      <a href="/admin/analytics" class="nav-item"><span>Analytics</span></a>
      <a href="/admin/settings" class="nav-item"><span>Settings</span></a>
    </nav>
  </aside>

  <main class="main-content">
    <section class="page-header">
      <h1>Escalated Reports</h1>
      <span class="report-count"><%= reports.length %> report<%= reports.length !== 1 ? 's' : '' %></span>
    </section>

    <% if (success && success.length) { %><div class="flash success"><%= success %></div><% } %>
    <% if (error && error.length) { %><div class="flash error"><%= error %></div><% } %>

    <section class="reports-list">
      <% if (reports.length === 0) { %>
        <p class="empty-state">No escalated reports at this time.</p>
      <% } else { %>
        <% reports.forEach(report => { %>
        <div class="report-card">
          <div class="report-meta">
            <span class="report-type"><%= report.targetType %> #<%= report.targetId %></span>
            <span class="report-date"><%= new Date(report.createdAt).toLocaleDateString() %></span>
          </div>
          <div class="report-reason"><strong>Reason:</strong> <%= report.reason %></div>
          <% if (report.reporter) { %>
            <div class="report-reporter">Reported by: <%= report.reporter.name %> (<%= report.reporter.email %>)</div>
          <% } %>
          <% if (report.notes) { %>
            <div class="report-notes"><strong>Notes:</strong> <%= report.notes %></div>
          <% } %>
          <div class="report-actions">
            <% if (report.targetType === 'post') { %>
              <form action="/admin/escalated/<%= report.id %>/remove" method="POST" style="display:inline"
                    onsubmit="return confirm('Delete this post and resolve the report?')">
                <button type="submit" class="btn-remove">Remove Post</button>
              </form>
            <% } %>
            <form action="/admin/escalated/<%= report.id %>/dismiss" method="POST" style="display:inline">
              <button type="submit" class="btn-dismiss">Dismiss</button>
            </form>
          </div>
        </div>
        <% }) %>
      <% } %>
    </section>
  </main>

  <footer>
    <div class="container">
      <span class="logo">C.M.D.</span>
      <p>Connect. Meet. Discover. &copy; 2026</p>
    </div>
  </footer>
</body>
</html>
