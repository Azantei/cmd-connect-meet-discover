<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analytics | C.M.D.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/AD_Analytics.css">
</head>
<body>
  <header class="admin-topbar">
    <span>System Administrator Dashboard</span>
    <span class="admin-role">System Administrator</span>
  </header>

  <nav class="top-navbar">
    <div class="navbar-content">
      <a href="/" class="logo"><span class="logo-light">C.M.</span><span class="logo-accent">D.</span></a>
      <div class="nav-links">
        <a href="/feed">Explore</a>
        <a href="/posts/create">Create</a>
        <a href="/users/profile">Profile</a>
        <a href="/about">About Us</a>
      </div>
      <div class="admin-info">Admin: <%= currentUsername %>
        <form action="/logout" method="POST" style="display:inline">
          <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
        </form>
      </div>
    </div>
  </nav>

  <aside class="left-sidebar">
    <nav class="sidebar-nav">
      <a href="/admin/users" class="nav-item"><span>Users</span></a>
      <a href="/admin/escalated" class="nav-item"><span>Escalated</span><% if (escalatedCount > 0) { %><span class="escalated-dot"></span><% } %></a>
      <a href="/admin/analytics" class="nav-item active"><span>Analytics</span></a>
      <a href="/admin/settings" class="nav-item"><span>Settings</span></a>
    </nav>
  </aside>

  <main class="main-content">
    <section class="page-header">
      <h1>Analytics</h1>
      <div class="date-selector">
        <label for="dateRange">Date range:</label>
        <select id="dateRange" class="date-filter">
          <option value="all">All Time</option>
          <option value="today">Today</option>
          <option value="week">This Week</option>
          <option value="month">This Month</option>
          <option value="quarter">This Quarter</option>
          <option value="year">This Year</option>
        </select>
      </div>
    </section>

    <section class="stats-grid">
      <div class="stat-card orange">
        <div class="stat-label">Total Users</div>
        <div class="stat-value" id="totalUsers"><%= userCount %></div>
      </div>
      <div class="stat-card orange">
        <div class="stat-label">Active Posts</div>
        <div class="stat-value" id="activePosts"><%= postCount %></div>
      </div>
      <div class="stat-card orange">
        <div class="stat-label">RSVPs</div>
        <div class="stat-value" id="rsvps"><%= rsvpCount %></div>
      </div>
      <div class="stat-card gray">
        <div class="stat-label">Reports</div>
        <div class="stat-value" id="reports"><%= reportCount %></div>
      </div>
    </section>

    <section class="chart-section">
      <div class="chart-header">
        <span class="chart-icon">&#9632;</span>
        <h2>User Growth Chart (bar/line &mdash; new users per day)</h2>
      </div>
      <div class="chart-container" id="userGrowthChart">
        <div class="chart-placeholder">
          <% if (growthData.length) { %>
            <% const maxGrowth = Math.max(...growthData.map(d => d.count), 1); %>
            <div class="bar-chart">
              <% growthData.forEach(function(d) { %>
                <div class="bar" style="height:<%= Math.round((d.count / maxGrowth) * 100) %>%" title="<%= d.date %>: <%= d.count %> new user<%= d.count !== 1 ? 's' : '' %>"></div>
              <% }); %>
            </div>
          <% } else { %>
            <p style="color:#888;font-size:0.9rem;text-align:center;padding:2rem 0;">No new registrations in this period.</p>
          <% } %>
        </div>
      </div>
    </section>

    <section class="bottom-grid">
      <div class="section-card">
        <div class="section-header">
          <span class="section-icon">&#9632;</span>
          <h3>Top Categories</h3>
        </div>
        <div class="categories-list">
          <% if (topCategories.length) { %>
            <% const maxCount = topCategories[0].count; %>
            <% topCategories.forEach(function(cat) { %>
              <div class="category-item">
                <span class="category-label"><%= cat.name %></span>
                <div class="category-bar" style="width:<%= Math.round((cat.count / maxCount) * 100) %>%"></div>
              </div>
            <% }); %>
          <% } else { %>
            <p style="color:#888;font-size:0.9rem;">No category data available.</p>
          <% } %>
        </div>
      </div>

      <div class="section-card">
        <div class="section-header">
          <span class="section-icon">&#9632;</span>
          <h3>Recent Activity Log</h3>
        </div>
        <div class="activity-list" id="activityLog">
          <% if (recentActivity.length) { %>
            <% recentActivity.forEach(function(log) { %>
              <div class="activity-item">
                <span class="activity-date"><%= log.date %></span>
                <span class="activity-separator">—</span>
                <span class="activity-text"><%= log.moderatorName %> <%= log.action %>d a <%= log.targetType %></span>
              </div>
            <% }); %>
          <% } else { %>
            <div class="activity-item">
              <span class="activity-date">—</span>
              <span class="activity-separator">—</span>
              <span class="activity-text" style="color:#888;">No recent moderation activity.</span>
            </div>
          <% } %>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <span class="logo">C.M.D.</span>
      <p>Connect. Meet. Discover. &copy; 2026</p>
    </div>
  </footer>

  <script>
    var ANALYTICS_START_DATE = '<%= startDate %>';
    var ANALYTICS_END_DATE   = '<%= endDate %>';
  </script>
  <script src="/js/AD_Analytics.js"></script>
</body>
</html>
