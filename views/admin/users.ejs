<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Management | C.M.D.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/AD_UserManagement.css">
</head>
<body>
  <header class="admin-topbar">
    <span>System Administrator Dashboard</span>
    <span class="admin-role">System Administrator</span>
  </header>

  <nav class="top-navbar">
    <div class="navbar-content">
      <a href="/" class="logo"><span class="logo-light">C.M.</span><span class="logo-accent">D.</span></a>
      <div class="nav-links">
        <a href="/events">Explore</a>
        <a href="/posts/create">Create</a>
        <a href="/users/profile">Profile</a>
        <a href="/about">About Us</a>
      </div>
      <div class="admin-info">Admin: <%= currentUsername %>
        <form action="/logout" method="POST" style="display:inline">
          <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
        </form>
      </div>
    </div>
  </nav>

  <aside class="left-sidebar">
    <nav class="sidebar-nav">
      <a href="/admin/users" class="nav-item active"><span>Users</span></a>
      <a href="/admin/escalated" class="nav-item"><span>Escalated</span></a>
      <a href="/admin/analytics" class="nav-item"><span>Analytics</span></a>
      <a href="/admin/settings" class="nav-item"><span>Settings</span></a>
    </nav>
  </aside>

  <main class="main-content">
    <% if (success && success.length) { %><div class="flash success"><%= success %></div><% } %>
    <% if (error && error.length) { %><div class="flash error"><%= error %></div><% } %>

    <section class="stats-section">
      <div class="stat-card">
        <div class="stat-label">Total Users</div>
        <div class="stat-value"><%= users.length %></div>
      </div>
    </section>

    <section class="table-section">
      <table class="users-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
            <th>Joined</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(user => { %>
          <tr>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
            <td><%= user.role %></td>
            <td><%= user.isBanned ? 'Banned' : 'Active' %></td>
            <td><%= new Date(user.createdAt).toLocaleDateString() %></td>
            <td class="action-btns">
              <% if (user.isBanned) { %>
                <form action="/admin/users/<%= user.id %>/unban" method="POST" style="display:inline">
                  <button type="submit" class="btn-unban">Unban</button>
                </form>
              <% } else { %>
                <form action="/admin/users/<%= user.id %>/ban" method="POST" style="display:inline">
                  <button type="submit" class="btn-ban">Ban</button>
                </form>
              <% } %>
              <% if (user.role === 'community_member') { %>
                <form action="/admin/users/<%= user.id %>/promote" method="POST" style="display:inline">
                  <button type="submit" class="btn-promote">Promote</button>
                </form>
              <% } else if (user.role === 'moderator') { %>
                <form action="/admin/users/<%= user.id %>/demote" method="POST" style="display:inline">
                  <button type="submit" class="btn-demote">Demote</button>
                </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>

  <footer>
    <div class="container">
      <span class="logo">C.M.D.</span>
      <p>Connect. Meet. Discover. &copy; 2026</p>
    </div>
  </footer>
</body>
</html>
