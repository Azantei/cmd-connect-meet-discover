<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Management | C.M.D.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/AD_UserManagement.css">
  <style>
    .admin-popup { position:fixed; top:1.5rem; left:50%; transform:translateX(-50%); padding:.75rem 1.5rem; border-radius:8px; font-size:.95rem; font-weight:600; box-shadow:0 4px 16px rgba(0,0,0,.2); z-index:10000; animation:adFadeIn .3s ease; }
    .admin-popup.success { background:#276749; color:#fff; }
    .admin-popup.error   { background:#c53030; color:#fff; }
    @keyframes adFadeIn { from{opacity:0;transform:translateX(-50%) translateY(-12px)} to{opacity:1;transform:translateX(-50%) translateY(0)} }
  </style>
</head>
<body>
  <header class="admin-topbar">
    <span>System Administrator Dashboard</span>
    <span class="admin-role">System Administrator</span>
  </header>

  <nav class="top-navbar">
    <div class="navbar-content">
      <a href="/" class="logo"><span class="logo-light">C.M.</span><span class="logo-accent">D.</span></a>
      <div class="nav-links">
        <a href="/feed">Explore</a>
        <a href="/posts/create">Create</a>
        <a href="/users/profile">Profile</a>
        <a href="/about">About Us</a>
      </div>
      <div class="admin-info">Admin: <%= currentUsername %>
        <form action="/logout" method="POST" style="display:inline">
          <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
        </form>
      </div>
    </div>
  </nav>

  <aside class="left-sidebar">
    <nav class="sidebar-nav">
      <a href="/admin/users" class="nav-item active"><span>Users</span></a>
      <a href="/admin/escalated" class="nav-item"><span>Escalated</span><% if (escalatedCount > 0) { %><span class="escalated-dot"></span><% } %></a>
      <a href="/admin/analytics" class="nav-item"><span>Analytics</span></a>
      <a href="/admin/settings" class="nav-item"><span>Settings</span></a>
    </nav>
  </aside>

  <% if (success && success.length) { %><div class="admin-popup success" id="adminPopup"><%= success %></div><% } %>
  <% if (error && error.length) { %><div class="admin-popup error" id="adminPopup"><%= error %></div><% } %>
  <% if (success && success.length || error && error.length) { %>
  <script>setTimeout(function(){ var el=document.getElementById('adminPopup'); if(el) el.remove(); }, 4000);</script>
  <% } %>

  <main class="main-content">

    <section class="stats-section">
      <div class="stat-card">
        <div class="stat-label">Total Users</div>
        <div class="stat-value" id="totalUsers"><%= totalUsers %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Active Posts</div>
        <div class="stat-value" id="activePosts"><%= activePosts %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Reports</div>
        <div class="stat-value" id="reports"><%= reportCount %></div>
      </div>
    </section>

    <section class="search-section">
      <input type="text" id="searchInput" placeholder="Search by name or email" class="search-input">
      <button class="search-btn">Search</button>
    </section>

    <section class="table-section">
      <table class="users-table">
        <thead>
          <tr>
            <th>User (name + email)</th>
            <th>Role</th>
            <th>Status</th>
            <th>Joined</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="usersTableBody"></tbody>
      </table>
    </section>
  </main>

  <div id="promoteModal" class="modal" style="display:none;position:fixed;inset:0;z-index:10001;align-items:center;justify-content:center;">
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.45);" onclick="closePromoteModal()"></div>
    <div style="position:relative;background:#fff;border-radius:12px;padding:2rem;max-width:420px;width:90%;box-shadow:0 8px 32px rgba(0,0,0,0.18);">
      <h2 style="margin:0 0 0.5rem;font-size:1.15rem;">Promote to Moderator</h2>
      <p id="promoteModalMsg" style="margin:0 0 1.5rem;color:#555;font-size:0.95rem;"></p>
      <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
        <button onclick="closePromoteModal()" style="padding:0.5rem 1.1rem;border:1px solid #ccc;border-radius:6px;background:#fff;cursor:pointer;font:inherit;">Cancel</button>
        <button id="promoteConfirmBtn" style="padding:0.5rem 1.1rem;border:none;border-radius:6px;background:hsl(220,70%,50%);color:#fff;font:inherit;font-weight:600;cursor:pointer;">Promote</button>
      </div>
    </div>
  </div>

  <div id="banModal" class="modal" style="display:none;position:fixed;inset:0;z-index:10001;align-items:center;justify-content:center;">
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.45);" onclick="closeBanModal()"></div>
    <div style="position:relative;background:#fff;border-radius:12px;padding:2rem;max-width:420px;width:90%;box-shadow:0 8px 32px rgba(0,0,0,0.18);">
      <h2 style="margin:0 0 0.5rem;font-size:1.15rem;color:#c53030;">Ban User</h2>
      <p id="banModalMsg" style="margin:0 0 1.5rem;color:#555;font-size:0.95rem;"></p>
      <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
        <button onclick="closeBanModal()" style="padding:0.5rem 1.1rem;border:1px solid #ccc;border-radius:6px;background:#fff;cursor:pointer;font:inherit;">Cancel</button>
        <button id="banConfirmBtn" style="padding:0.5rem 1.1rem;border:none;border-radius:6px;background:#c53030;color:#fff;font:inherit;font-weight:600;cursor:pointer;">Ban User</button>
      </div>
    </div>
  </div>

  <div id="unbanModal" class="modal" style="display:none;position:fixed;inset:0;z-index:10001;align-items:center;justify-content:center;">
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.45);" onclick="closeUnbanModal()"></div>
    <div style="position:relative;background:#fff;border-radius:12px;padding:2rem;max-width:420px;width:90%;box-shadow:0 8px 32px rgba(0,0,0,0.18);">
      <h2 style="margin:0 0 0.5rem;font-size:1.15rem;">Unban User</h2>
      <p id="unbanModalMsg" style="margin:0 0 1.5rem;color:#555;font-size:0.95rem;"></p>
      <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
        <button onclick="closeUnbanModal()" style="padding:0.5rem 1.1rem;border:1px solid #ccc;border-radius:6px;background:#fff;cursor:pointer;font:inherit;">Cancel</button>
        <button id="unbanConfirmBtn" style="padding:0.5rem 1.1rem;border:none;border-radius:6px;background:hsl(220,70%,50%);color:#fff;font:inherit;font-weight:600;cursor:pointer;">Unban User</button>
      </div>
    </div>
  </div>

  <footer>
    <div class="container">
      <span class="logo">C.M.D.</span>
      <p>Connect. Meet. Discover. &copy; 2026</p>
    </div>
  </footer>

  <script id="admin-users-data" type="application/json"><%- JSON.stringify(adminUsers) %></script>
  <script>
    var adminUsersDataEl = document.getElementById('admin-users-data');
    window.ADMIN_USERS = adminUsersDataEl ? JSON.parse(adminUsersDataEl.textContent || '[]') : [];
  </script>
  <script src="/js/AD_UserManagement.js"></script>
</body>
</html>
