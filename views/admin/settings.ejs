<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Platform Settings | C.M.D.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/AD_Settings.css">
  <style>
    .cat-inline-msg { background:#276749; color:#fff; padding:.55rem 1rem; border-radius:6px; font-size:.9rem; font-weight:600; margin-bottom:.75rem; display:inline-block; }
  </style>
</head>
<body>
  <header class="admin-topbar">
    <span>System Administrator Dashboard</span>
    <span class="admin-role">System Administrator</span>
  </header>

  <nav class="top-navbar">
    <div class="navbar-content">
      <a href="/" class="logo"><span class="logo-light">C.M.</span><span class="logo-accent">D.</span></a>
      <div class="nav-links">
        <a href="/events">Explore</a>
        <a href="/posts/create">Create</a>
        <a href="/users/profile">Profile</a>
        <a href="/about">About Us</a>
      </div>
      <div class="admin-info">Admin: <%= currentUsername %>
        <form action="/logout" method="POST" style="display:inline">
          <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
        </form>
      </div>
    </div>
  </nav>

  <aside class="left-sidebar">
    <nav class="sidebar-nav">
      <a href="/admin/users" class="nav-item"><span>Users</span></a>
      <a href="/admin/escalated" class="nav-item"><span>Escalated</span><% if (escalatedCount > 0) { %><span class="escalated-dot"></span><% } %></a>
      <a href="/admin/analytics" class="nav-item"><span>Analytics</span></a>
      <a href="/admin/settings" class="nav-item active"><span>Settings</span></a>
    </nav>
  </aside>

  <main class="main-content">
    <section class="page-header">
      <h1>Platform Settings</h1>
    </section>

    <% if (success && success.length) { %><div class="flash success"><%= success %></div><% } %>
    <% if (error && error.length) { %><div class="flash error"><%= error %></div><% } %>

    <section class="settings-tabs">
      <button class="tab-button active" data-tab="general">General</button>
      <button class="tab-button" data-tab="categories">Categories &amp; Tags</button>
    </section>

    <section id="general-tab" class="tab-content active">
      <h2>GENERAL SETTINGS</h2>
      <form action="/admin/settings" method="POST" id="generalSettingsForm">
        <div class="form-group">
          <label for="platformName">Platform Name</label>
          <input type="text" id="platformName" name="platformName" class="form-input"
                 value="<%= platformSettings.platformName || 'C.M.D. — Connect. Meet. Discover.' %>">
        </div>

        <div class="form-group">
          <label for="distanceRadius">Default Distance Radius</label>
          <input type="text" id="distanceRadius" name="distanceRadius" class="form-input"
                 value="<%= platformSettings.distanceRadius || '10 mi' %>">
        </div>

        <div class="action-buttons">
          <button type="submit" class="btn-save" id="saveChanges">Save Changes</button>
          <button type="button" class="btn-discard" id="discardChanges">Discard Changes</button>
        </div>
      </form>
    </section>

    <section id="categories-tab" class="tab-content">
      <h2>CATEGORIES &amp; TAGS</h2>

      <form action="/admin/settings/categories" method="POST" class="add-tag-section">
        <input type="text" id="newTagInput" name="name" class="form-input" placeholder="New category name..." required>
        <button type="submit" class="btn-add-tag" id="addTagBtn">+ Add</button>
      </form>

      <% if (catSuccess && catSuccess.length) { %>
        <div class="cat-inline-msg" id="catInlineMsg"><%= catSuccess %></div>
      <% } %>

      <div class="tags-container" id="tagsList">
        <% if (categories.length === 0) { %>
          <p class="empty-state">No categories yet.</p>
        <% } else { %>
          <% categories.forEach(cat => { %>
            <div class="tag-chip">
              <%= cat.name %>
              <button type="button" class="remove-tag"
                      onclick="openRemoveModal(<%= cat.id %>, '<%= cat.name.replace(/'/g, "\\'") %>')"
                      aria-label="Remove <%= cat.name %>">X</button>
            </div>
          <% }) %>
        <% } %>
      </div>
    </section>
  </main>

  <div id="removeModal" style="display:none;position:fixed;inset:0;z-index:10001;align-items:center;justify-content:center;">
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.45);" onclick="closeRemoveModal()"></div>
    <div style="position:relative;background:#fff;border-radius:12px;padding:2rem;max-width:400px;width:90%;box-shadow:0 8px 32px rgba(0,0,0,0.18);">
      <h2 style="margin:0 0 0.5rem;font-size:1.1rem;">Remove Category</h2>
      <p id="removeModalMsg" style="margin:0 0 1.5rem;color:#555;font-size:0.95rem;"></p>
      <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
        <button onclick="closeRemoveModal()" style="padding:0.5rem 1.1rem;border:1px solid #ccc;border-radius:6px;background:#fff;cursor:pointer;font:inherit;">Cancel</button>
        <button id="removeConfirmBtn" style="padding:0.5rem 1.1rem;border:none;border-radius:6px;background:#c53030;color:#fff;font:inherit;font-weight:600;cursor:pointer;">Remove</button>
      </div>
    </div>
  </div>
  <form id="removeForm" method="POST" style="display:none;"></form>

  <footer>
    <div class="container">
      <span class="logo">C.M.D.</span>
      <p>Connect. Meet. Discover. &copy; 2026</p>
    </div>
  </footer>

  <script>
    var SAVED_PLATFORM_SETTINGS = {
      platformName:   '<%= (platformSettings.platformName   || 'C.M.D. — Connect. Meet. Discover.').replace(/'/g, "\\'") %>',
      distanceRadius: '<%= (platformSettings.distanceRadius || '10 mi').replace(/'/g, "\\'") %>'
    };
  </script>
  <script src="/js/AD_Settings.js"></script>
</body>
</html>
