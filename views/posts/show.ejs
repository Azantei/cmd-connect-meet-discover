<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= post.title %> - C.M.D.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/CM_EventView.css">
</head>
<body>
<%- include('../partials/mod-topbar') %>
<%- include('../partials/admin-topbar') %>
    <nav class="navbar">
        <a href="/" class="brand"><span class="brand-light">C.M.</span><span class="brand-accent">D.</span></a>
        <div class="nav-links">
            <a href="/events">Explore</a>
            <a href="/posts/create">Create</a>
            <a href="/users/profile">Profile</a>
            <a href="/about">About Us</a>
        </div>
        <div class="nav-right">
            <% if (currentUser) { %>
                <span><%= currentUsername %></span>
                <form action="/logout" method="POST" style="display:inline">
                    <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
                </form>
            <% } else { %>
                <a href="/login" style="color:hsl(20,90%,55%);text-decoration:none;">Sign In</a>
            <% } %>
        </div>
    </nav>

    <% if (success && success.length && !(rsvpConfirmed && rsvpConfirmed.length) && !(rsvpCancelled && rsvpCancelled.length)) { %><div class="flash success"><%= success %></div><% } %>
    <% if (error && error.length && !(rsvpFull && rsvpFull.length)) { %><div class="flash error"><%= error %></div><% } %>

    <div class="banner">
        <% if (post.imageUrl) { %>
            <img src="<%= post.imageUrl %>" alt="Post banner" style="width:100%;height:100%;object-fit:cover;">
        <% } else { %>
            <div class="banner-icon"></div>
            <span class="banner-text">Post Banner Image</span>
        <% } %>
    </div>

    <div class="content">
        <div class="two-column-layout">
            <div class="left-column">
                <% if (post.date) { %>
                <div class="info-box">
                    <div class="info-label">📅 Date & Time</div>
                    <% var _pd = new Date(post.date); var _ph = _pd.getHours(), _pm = _pd.getMinutes(); %>
                    <div class="info-value">
                        <%= _pd.toDateString() %><% if (_ph || _pm) { var _sfx = _ph >= 12 ? 'PM' : 'AM'; var _h12 = _ph % 12 || 12; var _mm = String(_pm).padStart(2, '0'); %> &middot; <%= _h12 %>:<%= _mm %> <%= _sfx %><% } %>
                    </div>
                </div>
                <% } %>
                <% if (post.location) { %>
                <div class="info-box">
                    <div class="info-label">📍 Location</div>
                    <div class="info-value"><%= post.location %></div>
                </div>
                <% } %>
                <% if (post.type === 'event') { %>
                <div class="info-box">
                    <div class="info-label">👥 RSVPs</div>
                    <div class="info-value">
                        <%= rsvpCount %><% if (post.maxAttendees) { %>/<%= post.maxAttendees %><% } %> going
                    </div>
                </div>
                <% if (currentUser) { %>
                    <% if (hasRsvp) { %>
                        <form id="cancelRsvpForm" action="/posts/<%= post.id %>/rsvp?_method=DELETE" method="POST" style="margin-top:1rem;">
                            <button type="button" class="btn-rsvp rsvp-active" onclick="document.getElementById('cancelRsvpModal').style.display='flex'">Cancel RSVP</button>
                        </form>
                    <% } else { %>
                        <form action="/posts/<%= post.id %>/rsvp" method="POST" style="margin-top:1rem;">
                            <button type="submit" class="btn-rsvp">RSVP</button>
                        </form>
                    <% } %>
                <% } %>
                <% } %>
            </div>

            <div class="right-column">
                <h1 class="event-title"><%= post.title %></h1>

                <% if (post.category && post.category.length) { %>
                <div class="tags">
                    <% post.category.forEach(cat => { %><span class="tag"><%= cat %></span><% }) %>
                </div>
                <% } %>

                <% if (post.description) { %>
                <div class="desc-lines">
                    <div style="width:100%"><%= post.description %></div>
                </div>
                <% } %>

                <div class="action-row">
                    <% if (currentUser && currentUser !== post.userId) { %>
                        <button class="btn-interested <%= isInterested ? 'active' : '' %>" id="interestedBtn"
                                data-post-id="<%= post.id %>"
                                data-post-title="<%= post.title.replace(/"/g, '&quot;') %>"
                                data-post-desc="<%= post.description ? post.description.substring(0,100).replace(/"/g,'&quot;') : '' %>"
                                data-post-date="<%= post.date ? new Date(post.date).toDateString() : 'Date TBD' %>"
                                data-post-going="<%= rsvpCount %>"
                                data-post-max="<%= post.maxAttendees || '' %>"
                                data-post-tags="<%= JSON.stringify(Array.isArray(post.category) ? post.category : []) %>"
                                data-post-image="<%= post.imageUrl || '' %>"
                            onclick="toggleInterested()">&#9733; Interested<%= isInterested ? ' (saved)' : '' %></button>
                            <button class="btn-report" id="reportBtn" onclick="document.getElementById('reportModal').style.display='flex'">&#9889; Report Post</button>
                    <% } %>
                    <% if (currentUser === post.userId || currentRole === 'admin' || currentRole === 'moderator') { %>
                        <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" style="display:inline"
                              onsubmit="return confirm('Delete this post?')">
                            <button type="submit" class="btn-report" style="background:hsl(0,70%,55%);color:#fff;font-weight:700;">Delete Post</button>
                        </form>
                    <% } %>
                </div>

                <% if (post.author) { %>
                <div class="section-divider">
                    <h3 class="section-title">Post Creator</h3>
                </div>
                <div class="host-card">
                    <div class="host-left">
                        <div class="avatar"><%= post.author.name ? post.author.name.charAt(0).toUpperCase() : '?' %></div>
                        <div class="host-info">
                            <div class="host-name"><%= post.author.name %></div>
                            <div class="host-meta">
                                Posted <%= new Date(post.createdAt).toLocaleDateString() %> &middot;
                                <a href="/users/<%= post.author.id %>" class="view-profile">View profile</a>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </div>

    <% if (currentUser && currentUser !== post.userId) { %>
    <div class="modal-overlay" id="reportModal" style="display:none;">
        <div class="modal">
            <div class="modal-title">Report this post?</div>
            <div class="modal-desc">Please describe the issue. Our moderation team will review your report.</div>
            <form action="/posts/<%= post.id %>/report" method="POST">
                <div class="modal-reasons">
                    <label><input type="radio" name="reason" value="Spam or misleading content"> Spam or misleading content</label>
                    <label><input type="radio" name="reason" value="Inappropriate content"> Inappropriate content</label>
                    <label><input type="radio" name="reason" value="Harassment or bullying"> Harassment or bullying</label>
                    <label><input type="radio" name="reason" value="Violates community guidelines"> Violates community guidelines</label>
                    <label><input type="radio" name="reason" value="Other"> Other</label>
                </div>
                <div class="modal-comment-section">
                    <label for="reportComment" class="comment-label">Additional Comments (optional)</label>
                    <textarea id="reportComment" name="comment" class="report-textarea" rows="3"
                              placeholder="Provide any additional details..."></textarea>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-cancel" onclick="document.getElementById('reportModal').style.display='none'">Cancel</button>
                    <button type="submit" class="btn-submit">Submit Report</button>
                </div>
            </form>
        </div>
    </div>
    <% } %>

    <footer>
        <div class="container">
            <span class="logo">C.M.D.</span>
            <p>Connect. Meet. Discover. &copy; 2026</p>
        </div>
    </footer>

    <% if (reportSuccess && reportSuccess.length) { %>
    <div class="modal-overlay" id="reportSuccessModal" style="display:flex;">
        <div class="modal">
            <div class="modal-title">Report Submitted</div>
            <div class="modal-desc"><%= reportSuccess %></div>
            <div class="modal-actions" style="justify-content:center;">
                <button type="button" class="btn-submit" onclick="document.getElementById('reportSuccessModal').style.display='none'">OK</button>
            </div>
        </div>
    </div>
    <% } %>

    <% if (currentUser) { %>
    <div class="modal-overlay" id="cancelRsvpModal" style="display:none;">
        <div class="modal">
            <div class="modal-title">Cancel RSVP?</div>
            <div class="modal-desc">Are you sure you want to cancel your RSVP?</div>
            <div class="modal-actions">
                <button type="button" class="btn-cancel" onclick="document.getElementById('cancelRsvpModal').style.display='none'">No, Keep It</button>
                <button type="button" class="btn-submit" onclick="document.getElementById('cancelRsvpForm').submit()">Yes, Cancel RSVP</button>
            </div>
        </div>
    </div>
    <% } %>

    <% if (rsvpCancelled && rsvpCancelled.length) { %>
    <div class="modal-overlay" id="rsvpCancelledModal" style="display:flex;">
        <div class="modal">
            <div class="modal-title">RSVP Cancelled</div>
            <div class="modal-desc">Your RSVP has been cancelled.</div>
            <div class="modal-actions" style="justify-content:center;">
                <button type="button" class="btn-submit" onclick="document.getElementById('rsvpCancelledModal').style.display='none'">OK</button>
            </div>
        </div>
    </div>
    <% } %>

    <% if (rsvpConfirmed && rsvpConfirmed.length) { %>
    <div class="modal-overlay" id="rsvpConfirmedModal" style="display:flex;">
        <div class="modal">
            <div class="modal-title">RSVP Confirmed</div>
            <div class="modal-desc">RSVP'd &#10003;</div>
            <div class="modal-actions" style="justify-content:center;">
                <button type="button" class="btn-submit" onclick="document.getElementById('rsvpConfirmedModal').style.display='none'">OK</button>
            </div>
        </div>
    </div>
    <% } %>

    <% if (rsvpFull && rsvpFull.length) { %>
    <div class="modal-overlay" id="rsvpFullModal" style="display:flex;">
        <div class="modal">
            <div class="modal-title">RSVP Unavailable</div>
            <div class="modal-desc">This event is full. You can no longer RSVP.</div>
            <div class="modal-actions" style="justify-content:center;">
                <button type="button" class="btn-submit" onclick="document.getElementById('rsvpFullModal').style.display='none'">OK</button>
            </div>
        </div>
    </div>
    <% } %>

    <script src="/js/CM_EventView.js"></script>
</body>
</html>
