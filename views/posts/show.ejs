<%- include('../partials/header', { pageCSS: 'CM_Events' }) %>
<main>
  <h1><%= post.title %></h1>

  <% if (post.author) { %>
    <p>by <a href="/users/<%= post.author.id %>"><%= post.author.name %></a></p>
  <% } %>
  <% if (post.category) { %><span><%= post.category %></span><% } %>
  <% if (post.location) { %><span> &middot; <%= post.location %></span><% } %>
  <% if (post.date) { %><span> &middot; <%= new Date(post.date).toLocaleDateString() %></span><% } %>

  <% if (post.description) { %><p><%= post.description %></p><% } %>

  <p><strong><%= rsvpCount %></strong> RSVP<%= rsvpCount !== 1 ? 's' : '' %></p>

  <% if (currentUser) { %>
    <% if (hasRsvp) { %>
      <form action="/posts/<%= post.id %>/rsvp?_method=DELETE" method="POST" style="display:inline">
        <button type="submit">Cancel RSVP</button>
      </form>
    <% } else { %>
      <form action="/posts/<%= post.id %>/rsvp" method="POST" style="display:inline">
        <button type="submit">RSVP</button>
      </form>
    <% } %>
  <% } %>

  <% if (currentUser && currentUser !== post.userId) { %>
    <details>
      <summary>Report this post</summary>
      <form action="/posts/<%= post.id %>/report" method="POST">
        <textarea name="reason" required placeholder="Reason for report"></textarea>
        <button type="submit">Submit Report</button>
      </form>
    </details>
  <% } %>

  <% if (currentUser === post.userId || currentRole === 'admin' || currentRole === 'moderator') { %>
    <form action="/posts/<%= post.id %>?_method=DELETE" method="POST">
      <button type="submit">Delete Post</button>
    </form>
  <% } %>
</main>
<%- include('../partials/footer') %>
