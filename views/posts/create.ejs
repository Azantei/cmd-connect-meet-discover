<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>C.M.D. - Create a Post</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/CM_CreatePost.css">
</head>
<body>

    <nav class="navbar">
        <a href="/" class="brand"><span class="brand-light">C.M.</span><span class="brand-accent">D.</span></a>
        <div class="nav-links">
            <a href="/events">Explore</a>
            <a href="/posts/create">Create</a>
            <a href="/users/profile">Profile</a>
            <a href="/about">About Us</a>
        </div>
        <div class="nav-right">
            <% if (currentUser) { %>
                <span><%= currentUsername %></span>
                <form action="/logout" method="POST" style="display:inline">
                    <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
                </form>
            <% } else { %>
                <a href="/login" style="color:hsl(20,90%,55%);text-decoration:none;">Sign In</a>
            <% } %>
        </div>
    </nav>

    <% if (success && success.length) { %><div class="flash success"><%= success %></div><% } %>
    <% if (error && error.length) { %><div class="flash error"><%= error %></div><% } %>

    <div class="content">
        <h1 class="page-title">Create a Post</h1>

        <form action="/posts" method="POST" id="createPostForm">

            <div class="form-box">
                <div class="section-label">TITLE &amp; DESCRIPTION <span class="req">*</span></div>
                <div class="form-row border-bottom">
                    <label for="postTitle">Title</label>
                    <input type="text" id="postTitle" name="title" placeholder="Enter a title..." required />
                </div>
                <span class="error-message" id="title-error"></span>
                <div class="form-row textarea-row">
                    <label for="postDesc">Description</label>
                    <textarea rows="3" id="postDesc" name="description" placeholder="Describe your activity or gathering..."></textarea>
                </div>
            </div>

            <div class="form-box">
                <div class="section-label">DATE &amp; LOCATION <span class="optional">(optional)</span></div>
                <div class="form-row border-bottom">
                    <label for="postDate">Date</label>
                    <input type="date" id="postDate" name="date" />
                </div>
                <div class="form-row">
                    <label for="postLocation">Location</label>
                    <input type="text" id="postLocation" name="location" placeholder="Enter a location..." />
                </div>
            </div>

            <div class="form-box">
                <div class="categories-label">CATEGORIES <span class="optional">(optional)</span></div>
                <div class="pills" id="categoryPills">
                    <% categories.forEach(cat => { %>
                        <label class="pill">
                            <input type="checkbox" name="category" value="<%= cat.name %>"
                                   style="display:none"
                                   onchange="this.closest('.pill').classList.toggle('active', this.checked)">
                            <%= cat.name %>
                        </label>
                    <% }) %>
                </div>
                <span class="error-message" id="categories-error"></span>
            </div>

            <div class="actions">
                <a href="/feed" class="btn-cancel">Cancel</a>
                <div class="actions-right">
                    <button type="submit" class="btn-post">Post</button>
                </div>
            </div>

        </form>
    </div>

    <footer>
        <div class="container">
            <span class="logo">C.M.D.</span>
            <p>Connect. Meet. Discover. &copy; 2026</p>
        </div>
    </footer>

    <script src="/js/CM_CreatePost.js"></script>
</body>
</html>
