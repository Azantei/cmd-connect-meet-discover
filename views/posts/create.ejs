<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>C.M.D. - Create a Post</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/CM_CreatePost.css">
</head>
<body>
<%- include('../partials/mod-topbar') %>
<%- include('../partials/admin-topbar') %>
    <nav class="navbar">
        <a href="/" class="brand"><span class="brand-light">C.M.</span><span class="brand-accent">D.</span></a>
        <div class="nav-links">
            <a href="/events">Explore</a>
            <a href="/posts/create">Create</a>
            <a href="/users/profile">Profile</a>
            <a href="/about">About Us</a>
        </div>
        <div class="nav-right">
            <% if (currentUser) { %>
                <span><%= currentUsername %></span>
                <%- include('../partials/warning-indicator') %>
                <form action="/logout" method="POST" style="display:inline">
                    <button type="submit" style="margin-left:1rem;color:hsl(20,90%,55%);background:none;border:none;cursor:pointer;font:inherit;">Log Out</button>
                </form>
            <% } else { %>
                <a href="/login" style="color:hsl(20,90%,55%);text-decoration:none;">Sign In</a>
            <% } %>
        </div>
    </nav>

    <% if (error && error.length) { %>
        <div style="background:#fdecea;color:#c0392b;padding:0.75rem 1.5rem;font-size:0.88rem;text-align:center;border-bottom:1px solid #f5c6cb;"><%= error %></div>
    <% } %>

    <div class="content">
        <h1 class="page-title">Create a Post</h1>

        <form action="/posts" method="POST" id="createPostForm" enctype="multipart/form-data">
            <input type="hidden" name="status" id="postStatus" value="published">

            <!-- Title & Description -->
            <div class="form-box">
                <div class="section-label">TITLE &amp; DESCRIPTION <span class="req">*</span></div>
                <div class="form-row border-bottom">
                    <label for="eventTitle">Title</label>
                    <input type="text" id="eventTitle" name="title" placeholder="Enter a title..." />
                </div>
                <span class="error-message" id="title-error"></span>
                <div class="form-row textarea-row">
                    <label for="eventDesc">Description</label>
                    <textarea rows="3" id="eventDesc" name="description" placeholder="Describe your activity or gathering..."></textarea>
                </div>
                <span class="error-message" id="desc-error"></span>
            </div>

            <!-- Date, Time & Location -->
            <div class="form-box">
                <div class="section-label">DATE &amp; LOCATION <span class="optional">(optional)</span></div>
                <div class="form-row border-bottom">
                    <label for="eventDate">Date</label>
                    <input type="date" id="eventDate" name="date" />
                </div>
                <span class="error-message" id="date-error"></span>
                <div class="form-row border-bottom">
                    <label for="eventTime">Start Time</label>
                    <input type="time" id="eventTime" name="time" />
                </div>
                <span class="error-message" id="time-error"></span>
                <div class="form-row">
                    <label for="eventLocation">Location</label>
                    <input type="text" id="eventLocation" name="location" placeholder="Enter a location..." />
                </div>
                <span class="error-message" id="location-error"></span>
            </div>

            <!-- Categories -->
            <div class="form-box">
                <div class="categories-label">CATEGORIES <span class="optional">(optional)</span></div>
                <div class="pills" id="categoryPills">
                    <% categories.forEach(cat => { %>
                        <button type="button" class="pill"
                                data-name="<%= cat.name %>"
                                onclick="toggleCat(this)"><%= cat.name %></button>
                    <% }) %>
                </div>
                <span class="error-message" id="categories-error"></span>
                <div id="categoryInputs"></div>
            </div>

            <!-- RSVP Options -->
            <div class="form-box">
                <div class="section-label">RSVP OPTIONS <span class="optional">(optional)</span></div>
                <div class="form-row">
                    <label>Enable RSVP</label>
                    <label class="toggle-switch">
                        <input type="checkbox" id="rsvpToggle" name="rsvpEnabled" onchange="toggleRsvpOptions()">
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="form-row border-bottom" id="maxAttendeesRow" style="display:none;">
                    <label>Max Attendees<br><span class="optional">(optional)</span></label>
                    <input type="number" id="maxAttendees" name="maxAttendees" placeholder="Enter maximum number" min="1" />
                </div>
            </div>

            <!-- Banner Photo Upload -->
            <div class="form-box">
                <div class="section-label">EVENT BANNER <span class="optional">(optional)</span></div>
                <div class="form-row">
                    <input type="file" id="bannerUpload" name="imageUrl" accept="image/*"
                           onchange="handleBannerUpload(event)" style="padding: 12px 16px;" />
                    <div class="upload-note">Recommended size: 800x400px. Max 5MB.</div>
                </div>
            </div>

            <!-- Preview -->
            <div class="preview-section">
                <h2 class="preview-title">Post Preview</h2>
                <div class="preview-card" id="previewCard">
                    <div class="preview-banner" id="previewBanner">
                        <div class="preview-banner-placeholder">Banner photo will appear here</div>
                    </div>
                    <div class="preview-body">
                        <div class="preview-categories" id="previewCategories">
                            <span class="preview-tag">Select categories above</span>
                        </div>
                        <h3 class="preview-event-title" id="previewTitle">Your post title will appear here</h3>
                        <p class="preview-event-desc" id="previewDesc">Your description will appear here</p>
                        <div class="preview-event-details" id="previewDetails">
                            <span>📅 Date not set</span>
                            <span>📍 Location not set</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="actions">
                <a href="/posts" class="btn-cancel">Cancel</a>
                <div class="actions-right">
                    <button type="button" class="btn-draft" onclick="handleSaveDraft()">Save as Draft</button>
                    <button type="button" class="btn-post" onclick="handlePost()">Post</button>
                </div>
            </div>

        </form>
    </div>

    <footer>
        <div class="container">
            <span class="logo">C.M.D.</span>
            <p>Connect. Meet. Discover. &copy; 2026</p>
        </div>
    </footer>

    <script src="/js/CM_CreatePost.js"></script>
</body>
</html>
