<%- include('../partials/header', { pageCSS: 'CM_Events' }) %>
<main>
  <h1>Community Feed</h1>

  <form action="/posts" method="GET" style="margin-bottom:1rem;">
    <input type="text" name="q" value="<%= q %>" placeholder="Search posts..." />
    <select name="category">
      <option value="">All categories</option>
      <% categories.forEach(cat => { %>
        <option value="<%= cat.name %>" <%= selectedCategory === cat.name ? 'selected' : '' %>>
          <%= cat.name %>
        </option>
      <% }) %>
    </select>
    <button type="submit">Search</button>
    <% if (q || selectedCategory) { %>
      <a href="/posts">Clear</a>
    <% } %>
  </form>

  <% if (currentUser) { %><a href="/posts/new">+ New Post</a><% } %>

  <% if (posts.length === 0) { %>
    <p>No posts found.</p>
  <% } else { %>
    <% posts.forEach(post => { %>
      <div>
        <h2><a href="/posts/<%= post.id %>"><%= post.title %></a></h2>
        <% if (post.author) { %>
          <p>by <a href="/users/<%= post.author.id %>"><%= post.author.name %></a></p>
        <% } %>
        <% if (post.category) { %><span><%= post.category %></span><% } %>
        <% if (post.description) { %>
          <p><%= post.description.substring(0, 150) %><%= post.description.length > 150 ? '...' : '' %></p>
        <% } %>
        <small><%= new Date(post.createdAt).toLocaleDateString() %></small>
      </div>
    <% }) %>
  <% } %>
</main>
<%- include('../partials/footer') %>
