<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>C.M.D. - Connect. Meet. Discover.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/home.css">
</head>
<body>
<%- include('partials/mod-topbar') %>
<%- include('partials/admin-topbar') %>
    <nav>
        <div class="container">
            <a href="/" class="logo"><span class="logo-light">C.M.</span><span class="logo-accent">D.</span></a>
            <div class="nav-links">
                <a href="/events">Explore</a>
                <a href="/posts/create">Create</a>
                <a href="/users/profile">Profile</a>
                <a href="/about">About Us</a>
            </div>
            <div style="display:flex;align-items:center;gap:0.75rem;">
                <% if (currentUser) { %>
                    <span style="color:rgba(250,245,240,0.7);font-size:0.875rem;"><%= currentUsername %></span>
                    <form action="/logout" method="POST" style="display:inline">
                        <button type="submit" class="btn">Log Out</button>
                    </form>
                <% } else { %>
                    <button class="btn" onclick="window.location.href='/login'">Sign In</button>
                <% } %>
            </div>
        </div>
    </nav>

    <section class="hero">
        <div class="hero-bg">
            <div class="slideshow">
                <div class="slide active" style="background-image: url('/community.jpg')"></div>
                <div class="slide" style="background-image: url('/coffee.jpg')"></div>
                <div class="slide" style="background-image: url('/hiking.jpg')"></div>
                <div class="slide" style="background-image: url('/market.jpg')"></div>
            </div>
            <div class="hero-overlay"></div>
        </div>
        <div class="container">
            <div class="hero-content">
                <span class="hero-badge">Your neighborhood, reimagined</span>
                <h1>
                    Connect.<br>
                    Meet.<br>
                    <span class="highlight">Discover.</span>
                </h1>
                <p>
                    Create, discover, and join local activities and events. From spontaneous hangouts to organized gatherings. Your community awaits.
                </p>
                <div class="hero-buttons">
                    <button class="btn-primary" onclick="window.location.href='/login#signup'">Get Started</button>
                    <button class="btn-outline" onclick="window.location.href='/events'">Explore Events</button>
                </div>
            </div>
        </div>
    </section>

    <section class="features">
        <div class="container">
            <div class="section-header">
                <h2>Everything you need to <span class="highlight">connect</span></h2>
                <p>C.M.D. bridges casual, spontaneous community activities with organized events, fostering genuine engagement.</p>
            </div>
            <div class="feature-grid">
                <div class="feature-card">
                    <div class="feature-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                    </div>
                    <h3>Location-Based Discovery</h3>
                    <p>Find activities and events happening in your neighborhood with distance-based filtering and map integration.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    </div>
                    <h3>Dual-Mode Content</h3>
                    <p>Create casual activity posts for spontaneous hangouts or structured events with RSVP, all in one platform.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path><path d="M20 3v4"></path><path d="M22 5h-4"></path></svg>
                    </div>
                    <h3>Interest Matching</h3>
                    <p>Get personalized results based on your selected tags, categories, and interests.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
                    </div>
                    <h3>RSVP &amp; Attend</h3>
                    <p>Express interest, gauge attendance, and stay organized with built-in event management tools.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="how-it-works">
        <div class="container">
            <div class="section-header">
                <h2>How it <span class="highlight">works</span></h2>
            </div>
            <div class="steps-grid">
                <div class="step">
                    <span class="step-number">01</span>
                    <h3>Sign Up</h3>
                    <p>Create your profile and set your location and interests.</p>
                </div>
                <div class="step">
                    <span class="step-number">02</span>
                    <h3>Discover</h3>
                    <p>Browse local activities or search by category and distance.</p>
                </div>
                <div class="step">
                    <span class="step-number">03</span>
                    <h3>Connect</h3>
                    <p>RSVP, join events, and meet people in your community.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="cta">
        <div class="container">
            <h2>Ready to discover your community?</h2>
            <p>Join C.M.D. and start connecting with people, activities, and events near you.</p>
            <button class="btn-primary" onclick="window.location.href='/login#signup'">Join C.M.D. Today</button>
        </div>
    </section>

    <footer>
        <div class="container">
            <span class="logo">C.M.D.</span>
            <p>Connect. Meet. Discover. © 2026</p>
        </div>
    </footer>

    <script src="/js/home.js"></script>
</body>
</html>
